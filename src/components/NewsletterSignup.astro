---
// Renders nothing until a list backend is configured.
// Set to the Buttondown username once Jonah's account exists.
export const BUTTONDOWN_USERNAME: string | null = null;

interface Props {
  username?: string | null;
}
const username = Astro.props.username ?? BUTTONDOWN_USERNAME;
---

{username && (
  <section class="newsletter">
    <h2>Subscribe for news &amp; updates</h2>
    <p>Occasional emails when something new happens in the Wyld. No spam, easy unsubscribe.</p>
    <form action={`https://buttondown.com/api/emails/embed-subscribe/${username}`} method="post">
      <label class="visually-hidden" for="bd-email">Email address</label>
      <input type="email" name="email" id="bd-email" placeholder="you@example.com" required />
      <button type="submit">Sign up</button>
    </form>
  </section>
)}

<style>
  .newsletter {
    margin-top: 3rem;
    padding: 1.75rem;
    background: var(--bg-raised);
    border-radius: 8px;
    text-align: center;
  }
  .newsletter h2 { margin: 0 0 0.25rem; }
  .newsletter p { margin: 0 0 1.1rem; color: var(--text-dim); }
  form {
    display: flex;
    gap: 0.6rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  input {
    font: inherit;
    padding: 0.6rem 0.9rem;
    border: 1px solid var(--text-dim);
    border-radius: 6px;
    min-width: 16rem;
    background: var(--bg);
    color: var(--text);
  }
  button {
    font: inherit;
    font-weight: 700;
    background: var(--accent);
    color: #14110a;
    border: 0;
    border-radius: 6px;
    padding: 0.6rem 1.4rem;
    cursor: pointer;
  }
  button:hover { filter: brightness(1.1); }
  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }
</style>
