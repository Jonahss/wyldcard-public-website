---
import Base from '../layouts/Base.astro';
---

<Base
  title="Wyldcard — a new paradigm in tabletop gaming"
  description="Wyldcard: plastic cards with e-paper screens that meld the physical and the digital. Cards that change as you play, remember stats, and connect with friends."
>
  <section class="hero">
    <video autoplay muted loop playsinline width="1920" height="1080">
      <source src="/videos/introducing-wyldcard.webm" type="video/webm" />
      <source src="/videos/introducing-wyldcard.mp4" type="video/mp4" />
    </video>
    <h1>A new paradigm in tabletop gaming.</h1>
    <p class="tagline">Plastic cards with e-paper screens that meld the physical and the digital.</p>
  </section>

  <section>
    <p>
      Snap Wyldcards onto a <strong>Plinth</strong> and the pictures on the cards
      can <strong>change</strong> as you play the game. With built-in memory, Wyldcards can persist
      stats, log moves, and track status effects. Connect your Plinth with a friend's to
      collaborate or compete.
    </p>
    <p>
      We're partnering with Crowd Supply to launch our first Wyldcard DevKit — giving creators
      the ability to experiment with this new platform.
    </p>
    <p class="cta-row">
      <a class="cta" href="https://www.crowdsupply.com/wyldcard/wyldcard-devkit">Order Your DevKit Here</a>
    </p>
    <img src="/images/hero.webp" alt="Wyldcard e-paper gaming cards" width="1435" height="956" loading="lazy" />
  </section>

  <section>
    <h2>See it in action</h2>
    <iframe
      src="https://www.youtube-nocookie.com/embed/fpzheWk8_Nk"
      title="Wyldcard demo video"
      width="720"
      height="405"
      loading="lazy"
      allow="accelerometer; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen></iframe>
  </section>
</Base>

<style>
  .hero { text-align: center; }
  .hero h1 { font-size: 2rem; margin: 1.25rem 0 0.25rem; }
  .tagline { color: var(--text-dim); font-size: 1.15rem; margin-top: 0.25rem; }
  .cta-row { text-align: center; margin-top: 1.75rem; }
  .cta {
    display: inline-block;
    background: var(--accent);
    color: #14110a;
    font-weight: 700;
    text-decoration: none;
    padding: 0.7rem 1.4rem;
    border-radius: 6px;
  }
  .cta:hover { filter: brightness(1.1); }
  iframe { aspect-ratio: 16 / 9; width: 100%; height: auto; border: 0; }
</style>
